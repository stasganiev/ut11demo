    <attributes uuid="342d2810-0c06-455d-8bb0-26d2ff8d4aab">
      <name>小褌邪褌褍褋校泻邪蟹邪薪懈褟小械褉懈泄</name>
      <synonym>
        <key>ru</key>
        <value>小褌邪褌褍褋 褍泻邪蟹邪薪懈褟 褋械褉懈泄</value>
      </synonym>
      <type>
        <types>Number</types>
        <numberQualifiers>
          <precision>2</precision>
          <nonNegative>true</nonNegative>
        </numberQualifiers>
      </type>
      <toolTip>
        <key>ru</key>
        <value>小谢褍卸械斜薪褘泄 褉械泻胁懈蟹懈褌 泻芯褌芯褉褘泄 芯锌褉械写械谢褟械褌 褋芯褋褌芯褟薪懈械 胁胁芯写邪 褋械褉懈泄 写谢褟 褋褌褉芯泻懈 孝效. 肖芯褉屑懈褉褍械褌褋褟 邪胁褌芯屑邪褌懈褔械褋泻懈, 锌芯谢褜蟹芯胁邪褌械谢械屑 薪械 褉械写邪泻褌懈褉褍械褌褋褟.</value>
      </toolTip>
