	ОбластьМакета.Параметры.Организация        = СведенияОбОрганизации.ПолноеНаименование;
	ОбластьМакета.Параметры.ИНН                = СведенияОбОрганизации.ИНН;
	ОбластьМакета.Параметры.КПП                = СведенияОбОрганизации.КПП;
	ОбластьМакета.Параметры.ЮридическийАдрес   = СведенияОбОрганизации.ЮридическийАдрес;
	ОбластьМакета.Параметры.БанкНаименование   = ВыборкаШапка.БанкНаименование;
	ОбластьМакета.Параметры.БИК                = ВыборкаШапка.БИК;
	ОбластьМакета.Параметры.РасчетныйСчет     = ВыборкаШапка.РасчетныйСчет;
	ОбластьМакета.Параметры.КоррСчет           = ВыборкаШапка.КоррСчет;

	ТабличныйДокумент.Вывести(ОбластьМакета);

КонецПроцедуры

