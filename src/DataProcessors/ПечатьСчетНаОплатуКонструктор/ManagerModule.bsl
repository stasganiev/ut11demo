Процедура ВывестиБлокТаблицаТоваровДетальная(ТабличныйДокумент, Макет, КонтекстДанных)

	ВыборкаШапка = КонтекстДанных.ВыборкаШапка;

	// Шапка таблицы
	ОбластьШапка = Макет.ПолучитьОбласть("ТаблицаТоваровДетальная_Шапка");
	ТабличныйДокумент.Вывести(ОбластьШапка);

	// Строки таблицы
	ОбластьСтрока = Макет.ПолучитьОбласть("ТаблицаТоваровДетальная_Строка");
	НомерСтроки = 0;
	Для Каждого СтрокаТовара Из КонтекстДанных.СтрокиТоваров Цикл

		НомерСтроки = НомерСтроки + 1;

		ПредставлениеНоменклатуры = ПредставлениеНоменклатурыДляПечати(СтрокаТовара);

		Если ВыборкаШапка.ЦенаВключаетНДС Тогда
			ВсегоПоСтроке = СтрокаТовара.Сумма;
		Иначе
			ВсегоПоСтроке = СтрокаТовара.Сумма + СтрокаТовара.СуммаНДС;
		КонецЕсли;

		ОбластьСтрока.Параметры.НомерСтроки      = НомерСтроки;
		ОбластьСтрока.Параметры.Номенклатура      = ПредставлениеНоменклатуры;
		ОбластьСтрока.Параметры.ЕдиницаИзмерения  = СтрокаТовара.ЕдиницаИзмерения;
		ОбластьСтрока.Параметры.Количество         = СтрокаТовара.Количество;
		ОбластьСтрока.Параметры.Цена               = СтрокаТовара.Цена;
		ОбластьСтрока.Параметры.Сумма              = СтрокаТовара.Сумма;
		ОбластьСтрока.Параметры.СтавкаНДС          = СтрокаТовара.СтавкаНДС;
		ОбластьСтрока.Параметры.СуммаНДС           = СтрокаТовара.СуммаНДС;
		ОбластьСтрока.Параметры.Всего              = ВсегоПоСтроке;

		ТабличныйДокумент.Вывести(ОбластьСтрока);

	КонецЦикла;

	// Подвал таблицы
	ОбластьПодвал = Макет.ПолучитьОбласть("ТаблицаТоваровДетальная_Подвал");
	ОбластьПодвал.Параметры.ИтогоСумма    = КонтекстДанных.ИтогоСумма;
	ОбластьПодвал.Параметры.ИтогоНДС      = КонтекстДанных.ИтогоНДС;
	ОбластьПодвал.Параметры.ИтогоВсего    = КонтекстДанных.ИтогоВсего;
	ОбластьПодвал.Параметры.СуммаПрописью = КонтекстДанных.СуммаПрописью;

	ТабличныйДокумент.Вывести(ОбластьПодвал);

КонецПроцедуры

Процедура ВывестиБлокТаблицаТоваровИтоги(ТабличныйДокумент, Макет, КонтекстДанных)

	ОбластьМакета = Макет.ПолучитьОбласть("ТаблицаТоваровИтоги");
	ОбластьМакета.Параметры.ИтогоВсего    = КонтекстДанных.ИтогоВсего;
	ОбластьМакета.Параметры.ИтогоНДС      = КонтекстДанных.ИтогоНДС;
	ОбластьМакета.Параметры.СуммаПрописью = КонтекстДанных.СуммаПрописью;

	ТабличныйДокумент.Вывести(ОбластьМакета);

КонецПроцедуры

Процедура ВывестиБлокЭтапыОплаты(ТабличныйДокумент, Макет, КонтекстДанных)

	СтрокиЭтапов = КонтекстДанных.СтрокиЭтапов;
	Если СтрокиЭтапов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ОбластьШапка = Макет.ПолучитьОбласть("ЭтапыОплаты_Шапка");
	ТабличныйДокумент.Вывести(ОбластьШапка);

	ОбластьСтрока = Макет.ПолучитьОбласть("ЭтапыОплаты_Строка");
	НомерЭтапа = 0;
	Для Каждого СтрокаЭтапа Из СтрокиЭтапов Цикл

		НомерЭтапа = НомерЭтапа + 1;

		ОбластьСтрока.Параметры.НомерЭтапа      = НомерЭтапа;
		ОбластьСтрока.Параметры.ЭтапОплаты      = СтрокаЭтапа.ЭтапОплаты;
		ОбластьСтрока.Параметры.ДатаПлатежа      = Формат(СтрокаЭтапа.ДатаПлатежа, "ДЛФ=D");
		ОбластьСтрока.Параметры.СуммаПлатежа     = СтрокаЭтапа.СуммаПлатежа;
		ОбластьСтрока.Параметры.ПроцентПлатежа   = СтрокаЭтапа.ПроцентПлатежа;

		ТабличныйДокумент.Вывести(ОбластьСтрока);

	КонецЦикла;

КонецПроцедуры

Процедура ВывестиБлокПодписиПолные(ТабличныйДокумент, Макет, КонтекстДанных)

	ВыборкаШапка = КонтекстДанных.ВыборкаШапка;

	ОбластьМакета = Макет.ПолучитьОбласть("ПодписиПолные");
	ОбластьМакета.Параметры.Руководитель    = ВыборкаШапка.Руководитель;
	ОбластьМакета.Параметры.ГлавныйБухгалтер = ВыборкаШапка.ГлавныйБухгалтер;

	ТабличныйДокумент.Вывести(ОбластьМакета);

КонецПроцедуры

Процедура ВывестиБлокПодписиМенеджер(ТабличныйДокумент, Макет, КонтекстДанных)

	ВыборкаШапка = КонтекстДанных.ВыборкаШапка;

	ОбластьМакета = Макет.ПолучитьОбласть("ПодписиМенеджер");
	ОбластьМакета.Параметры.Менеджер = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(
		ВыборкаШапка.Менеджер, ВыборкаШапка.Дата);

	ТабличныйДокумент.Вывести(ОбластьМакета);

КонецПроцедуры

Процедура ВывестиБлокПримечание(ТабличныйДокумент, Макет, КонтекстДанных)

	ВыборкаШапка = КонтекстДанных.ВыборкаШапка;
	Если ПустаяСтрока(ВыборкаШапка.Комментарий) Тогда
		Возврат;
	КонецЕсли;

	ОбластьМакета = Макет.ПолучитьОбласть("ПримечаниеКДокументу");
	ОбластьМакета.Параметры.Примечание = ВыборкаШапка.Комментарий;

	ТабличныйДокумент.Вывести(ОбластьМакета);

КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеФункции

Процедура ДобавитьОписаниеБлока(Массив, Идентификатор, Представление, Включен, Группа)

	Блок = Новый Структура;
	Блок.Вставить("Идентификатор", Идентификатор);
	Блок.Вставить("Представление", Представление);
	Блок.Вставить("Включен",       Включен);
	Блок.Вставить("Группа",        Группа);
	Массив.Добавить(Блок);

КонецПроцедуры

// Формирует представление номенклатуры с учётом характеристики и содержания строки.
Функция ПредставлениеНоменклатурыДляПечати(СтрокаТовара)

	Результат = СокрЛП(СтрокаТовара.НоменклатураНаименованиеПолное);
	Если ПустаяСтрока(Результат) Тогда
		Результат = СокрЛП(СтрокаТовара.НоменклатураПредставление);
	КонецЕсли;

	Если НЕ ПустаяСтрока(СтрокаТовара.Характеристика) Тогда
		Результат = Результат + " (" + СокрЛП(СтрокаТовара.Характеристика) + ")";
	КонецЕсли;

	Если НЕ ПустаяСтрока(СтрокаТовара.Содержание) Тогда
		Результат = СокрЛП(СтрокаТовара.Содержание);
	КонецЕсли;

	Возврат Результат;

КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли
