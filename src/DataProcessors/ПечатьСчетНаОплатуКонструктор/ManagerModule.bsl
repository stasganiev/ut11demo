#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет список команд печати.
// Команда регистрируется в Документ.ЗаказКлиента.ДобавитьКомандыПечати().
//
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт

КонецПроцедуры

// Формирует печатные формы (точка входа по паттерну БСП).
//
// Параметры:
//   МассивОбъектов  - Массив из ДокументСсылка - ссылки на объекты печати.
//   ПараметрыПечати - Структура - дополнительные настройки.
//   КоллекцияПечатныхФорм - ТаблицаЗначений - коллекция для вывода сформированных табличных документов.
//   ОбъектыПечати   - СписокЗначений - соответствие объекта и имени области в табличном документе.
//   ПараметрыВывода  - Структура - параметры вывода (см. УправлениеПечатью.ПодготовитьСтруктуруПараметровВывода).
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт

	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СчетНаОплатуКонструктор") Тогда

		ВсеБлоки = НастройкиБлоковПоУмолчанию();
		АктивныеБлоки = Новый Массив;
		Для Каждого Блок Из ВсеБлоки Цикл
			Если Блок.Включен Тогда
				АктивныеБлоки.Добавить(Блок);
			КонецЕсли;
		КонецЦикла;

		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм,
			"СчетНаОплатуКонструктор",
			НСтр("ru = 'Счёт на оплату (конструктор)'"),
			СформироватьТабличныйДокументПоБлокам(МассивОбъектов, АктивныеБлоки));

	КонецЕсли;

КонецПроцедуры

// Формирует табличный документ по выбранным блокам.
//
// Параметры:
//   МассивОбъектов  - Массив из ДокументСсылка.ЗаказКлиента - ссылки на печатаемые документы.
//   НастройкиБлоков - Массив из Структура - активные блоки в нужном порядке:
//     * Идентификатор - Строка - идентификатор блока.
//
// Возвращаемое значение:
//   ТабличныйДокумент - сформированная печатная форма.
//
Функция СформироватьТабличныйДокументПоБлокам(МассивОбъектов, НастройкиБлоков) Экспорт

	УстановитьПривилегированныйРежим(Истина);

	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_СчетНаОплатуКонструктор";

	Макет = УправлениеПечатью.МакетПечатнойФормы(
		"Обработка.ПечатьСчетНаОплатуКонструктор.ПФ_MXL_СчетНаОплатуКонструктор");

	ДанныеДляПечати = ПолучитьДанныеДляПечати(МассивОбъектов);

	ТаблицаТоваровВсе = ДанныеДляПечати.Товары.Выгрузить();
	ТаблицаЭтаповВсе  = ДанныеДляПечати.ЭтапыОплаты.Выгрузить();

	ВыборкаШапка = ДанныеДляПечати.Шапка.Выбрать();
	ПервыйДокумент = Истина;

	Пока ВыборкаШапка.Следующий() Цикл

		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;

		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
			ВыборкаШапка.Организация, ВыборкаШапка.Дата);

		СведенияОКонтрагенте = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(
			ВыборкаШапка.Контрагент, ВыборкаШапка.Дата);

		ТекстЗаголовка = ОбщегоНазначенияУТКлиентСервер.СформироватьЗаголовокДокумента(
			ВыборкаШапка, НСтр("ru = 'Счет на оплату'"));

		СтрокиТоваров = ТаблицаТоваровВсе.НайтиСтроки(Новый Структура("Ссылка", ВыборкаШапка.Ссылка));
		СтрокиЭтапов  = ТаблицаЭтаповВсе.НайтиСтроки(Новый Структура("Ссылка", ВыборкаШапка.Ссылка));

		ИтогоСумма = 0;
		ИтогоНДС   = 0;
		Для Каждого СтрокаТовара Из СтрокиТоваров Цикл
			ИтогоСумма = ИтогоСумма + СтрокаТовара.Сумма;
			ИтогоНДС   = ИтогоНДС + СтрокаТовара.СуммаНДС;
		КонецЦикла;

		Если ВыборкаШапка.ЦенаВключаетНДС Тогда
			ИтогоВсего = ИтогоСумма;
		Иначе
			ИтогоВсего = ИтогоСумма + ИтогоНДС;
		КонецЕсли;

		СуммаПрописью = РаботаСКурсамиВалютУТ.СформироватьСуммуПрописью(
			ИтогоВсего, ВыборкаШапка.Валюта);

		КонтекстДанных = Новый Структура;
		КонтекстДанных.Вставить("ВыборкаШапка",          ВыборкаШапка);
		КонтекстДанных.Вставить("СведенияОбОрганизации",  СведенияОбОрганизации);
		КонтекстДанных.Вставить("СведенияОКонтрагенте",   СведенияОКонтрагенте);
		КонтекстДанных.Вставить("ТекстЗаголовка",         ТекстЗаголовка);
		КонтекстДанных.Вставить("СтрокиТоваров",          СтрокиТоваров);
		КонтекстДанных.Вставить("СтрокиЭтапов",           СтрокиЭтапов);
		КонтекстДанных.Вставить("ИтогоСумма",             ИтогоСумма);
		КонтекстДанных.Вставить("ИтогоНДС",               ИтогоНДС);
		КонтекстДанных.Вставить("ИтогоВсего",             ИтогоВсего);
		КонтекстДанных.Вставить("СуммаПрописью",          СуммаПрописью);

		Для Каждого НастройкаБлока Из НастройкиБлоков Цикл
			ВывестиБлок(ТабличныйДокумент, Макет, НастройкаБлока.Идентификатор, КонтекстДанных);
		КонецЦикла;

	КонецЦикла;

	УстановитьПривилегированныйРежим(Ложь);

	Возврат ТабличныйДокумент;

КонецФункции

// Возвращает настройки блоков по умолчанию.
//
// Возвращаемое значение:
//   Массив из Структура:
//     * Идентификатор - Строка - идентификатор блока.
//     * Представление - Строка - отображаемое имя.
//     * Включен       - Булево - включён ли блок по умолчанию.
//     * Группа        - Строка - группа взаимоисключения (пустая строка - без группы).
//
Функция НастройкиБлоковПоУмолчанию() Экспорт

	Результат = Новый Массив;

	ДобавитьОписаниеБлока(Результат, "ШапкаПолная",             НСтр("ru = 'Шапка полная'"),                Истина,  "Шапка");
	ДобавитьОписаниеБлока(Результат, "ШапкаКраткая",            НСтр("ru = 'Шапка краткая'"),               Ложь,    "Шапка");
	ДобавитьОписаниеБлока(Результат, "РеквизитыПокупателя",     НСтр("ru = 'Реквизиты покупателя'"),        Истина,  "");
	ДобавитьОписаниеБлока(Результат, "ТаблицаТоваровДетальная", НСтр("ru = 'Таблица товаров (детальная)'"), Истина,  "Товары");
	ДобавитьОписаниеБлока(Результат, "ТаблицаТоваровИтоги",     НСтр("ru = 'Таблица товаров (итоги)'"),     Ложь,    "Товары");
	ДобавитьОписаниеБлока(Результат, "ЭтапыОплаты",             НСтр("ru = 'Этапы оплаты'"),                Ложь,    "");
	ДобавитьОписаниеБлока(Результат, "ПодписиПолные",           НСтр("ru = 'Подписи (полные)'"),            Истина,  "Подписи");
	ДобавитьОписаниеБлока(Результат, "ПодписиМенеджер",         НСтр("ru = 'Подпись менеджера'"),            Ложь,    "Подписи");
	ДобавитьОписаниеБлока(Результат, "ПримечаниеКДокументу",    НСтр("ru = 'Примечание'"),                  Ложь,    "");

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПолучениеДанных

// Возвращает данные для формирования печатной формы.
//
// Параметры:
//   МассивОбъектов - Массив из ДокументСсылка.ЗаказКлиента
//
// Возвращаемое значение:
//   Структура:
//     * Шапка        - РезультатЗапроса
//     * Товары       - РезультатЗапроса
//     * ЭтапыОплаты  - РезультатЗапроса
//
Функция ПолучитьДанныеДляПечати(МассивОбъектов)

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ОтветственныеЛицаСервер.СформироватьВременнуюТаблицуОтветственныхЛицДокументов(
		МассивОбъектов, МенеджерВременныхТаблиц);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	Документы.Ссылка КАК Ссылка,
	|	Документы.Номер КАК Номер,
	|	Документы.Дата КАК Дата,
	|	Документы.Организация.Префикс КАК Префикс,
	|	ЕСТЬNULL(Документы.БанковскийСчет.Владелец, Документы.Организация) КАК Организация,
	|	Документы.Контрагент КАК Контрагент,
	|	Документы.Валюта КАК Валюта,
	|	Документы.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	ВЫБОР
	|		КОГДА Документы.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС)
	|			ИЛИ Документы.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаОблагаетсяЕНВД)
	|			ИЛИ Документы.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаПоПатенту)
	|			ИЛИ Документы.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК УчитыватьНДС,
	|	Документы.БанковскийСчет.НомерСчета КАК РасчетныйСчет,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.РучноеИзменениеРеквизитовБанка
	|			ТОГДА Документы.БанковскийСчет.НаименованиеБанка
	|		ИНАЧЕ КлассификаторБанков.Наименование
	|	КОНЕЦ КАК БанкНаименование,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.РучноеИзменениеРеквизитовБанка
	|			ТОГДА Документы.БанковскийСчет.БИКБанка
	|		ИНАЧЕ КлассификаторБанков.Код
	|	КОНЕЦ КАК БИК,
	|	ВЫБОР
	|		КОГДА Документы.БанковскийСчет.РучноеИзменениеРеквизитовБанка
	|			ТОГДА Документы.БанковскийСчет.КоррСчетБанка
	|		ИНАЧЕ КлассификаторБанков.КоррСчет
	|	КОНЕЦ КАК КоррСчет,
	|	ТаблицаОтветственныеЛица.РуководительНаименование КАК Руководитель,
	|	ТаблицаОтветственныеЛица.ГлавныйБухгалтерНаименование КАК ГлавныйБухгалтер,
	|	Документы.Менеджер.ФизическоеЛицо КАК Менеджер,
	|	Документы.ДополнительнаяИнформация КАК Комментарий
	|ИЗ
	|	Документ.ЗаказКлиента КАК Документы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаОтветственныеЛица КАК ТаблицаОтветственныеЛица
	|		ПО Документы.Ссылка = ТаблицаОтветственныеЛица.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК КлассификаторБанков
	|		ПО Документы.БанковскийСчет.Банк = КлассификаторБанков.Ссылка
	|ГДЕ
	|	Документы.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Документы.МоментВремени
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Ссылка КАК Ссылка,
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура) КАК НоменклатураПредставление,
	|	Товары.Номенклатура.НаименованиеПолное КАК НоменклатураНаименованиеПолное,
	|	ПРЕДСТАВЛЕНИЕ(Товары.Характеристика) КАК Характеристика,
	|	ВЫБОР
	|		КОГДА Товары.Номенклатура.ЕдиницаДляОтчетов <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаДляОтчетов)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаИзмерения)
	|	КОНЕЦ КАК ЕдиницаИзмерения,
	|	Товары.КоличествоУпаковок КАК Количество,
	|	Товары.Цена КАК Цена,
	|	Товары.Сумма КАК Сумма,
	|	ПРЕДСТАВЛЕНИЕ(Товары.СтавкаНДС) КАК СтавкаНДС,
	|	Товары.СуммаНДС КАК СуммаНДС,
	|	Товары.Содержание КАК Содержание
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка В(&МассивОбъектов)
	|	И Товары.Отменено = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Товары.Ссылка,
	|	Товары.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЭтапыГрафикаОплаты.Ссылка КАК Ссылка,
	|	ЭтапыГрафикаОплаты.НомерСтроки КАК НомерСтроки,
	|	ПРЕДСТАВЛЕНИЕ(ЭтапыГрафикаОплаты.ВариантОплаты) КАК ЭтапОплаты,
	|	ЭтапыГрафикаОплаты.ДатаПлатежа КАК ДатаПлатежа,
	|	ЭтапыГрафикаОплаты.СуммаПлатежа КАК СуммаПлатежа,
	|	ЭтапыГрафикаОплаты.ПроцентПлатежа КАК ПроцентПлатежа
	|ИЗ
	|	Документ.ЗаказКлиента.ЭтапыГрафикаОплаты КАК ЭтапыГрафикаОплаты
	|ГДЕ
	|	ЭтапыГрафикаОплаты.Ссылка В(&МассивОбъектов)
	|	И ЭтапыГрафикаОплаты.СуммаПлатежа <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ЭтапыГрафикаОплаты.Ссылка,
	|	ЭтапыГрафикаОплаты.НомерСтроки";

	РезультатыЗапроса = Запрос.ВыполнитьПакет();

	Результат = Новый Структура;
	Результат.Вставить("Шапка",        РезультатыЗапроса[0]);
	Результат.Вставить("Товары",       РезультатыЗапроса[1]);
	Результат.Вставить("ЭтапыОплаты",  РезультатыЗапроса[2]);

	Возврат Результат;

КонецФункции

#КонецОбласти

#Область ВыводБлоков

Процедура ВывестиБлок(ТабличныйДокумент, Макет, ИдентификаторБлока, КонтекстДанных)

	Если ИдентификаторБлока = "ШапкаПолная" Тогда
		ВывестиБлокШапкаПолная(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ШапкаКраткая" Тогда
		ВывестиБлокШапкаКраткая(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "РеквизитыПокупателя" Тогда
		ВывестиБлокРеквизитыПокупателя(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ТаблицаТоваровДетальная" Тогда
		ВывестиБлокТаблицаТоваровДетальная(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ТаблицаТоваровИтоги" Тогда
		ВывестиБлокТаблицаТоваровИтоги(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ЭтапыОплаты" Тогда
		ВывестиБлокЭтапыОплаты(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ПодписиПолные" Тогда
		ВывестиБлокПодписиПолные(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ПодписиМенеджер" Тогда
		ВывестиБлокПодписиМенеджер(ТабличныйДокумент, Макет, КонтекстДанных);

	ИначеЕсли ИдентификаторБлока = "ПримечаниеКДокументу" Тогда
		ВывестиБлокПримечание(ТабличныйДокумент, Макет, КонтекстДанных);

	КонецЕсли;

КонецПроцедуры

